# Agent Orchestration System Configuration

# Auto-scaling Settings
AGENT_AUTO_SCALING_ENABLED=true
AGENT_MAX_PER_TYPE=10
AGENT_MIN_PER_TYPE=1

# Scaling Thresholds (0-1)
AGENT_SCALE_UP_THRESHOLD=0.8
AGENT_SCALE_DOWN_THRESHOLD=0.2

# Health Monitoring
AGENT_HEALTH_CHECK_INTERVAL=30  # seconds
AGENT_HEARTBEAT_INTERVAL=10     # seconds
AGENT_HEARTBEAT_TIMEOUT=60      # seconds

# Task Management
AGENT_TASK_TIMEOUT=300          # seconds (5 minutes)
AGENT_TASK_QUEUE_SIZE=1000

# Initial Agents (spawned on startup)
AGENT_INITIAL_VERIFIERS=2
AGENT_INITIAL_ANALYZERS=1
AGENT_INITIAL_COORDINATORS=1

# Agent Capabilities
AGENT_VERIFIER_MAX_CONCURRENT=5
AGENT_ANALYZER_MAX_CONCURRENT=10
AGENT_COORDINATOR_MAX_CONCURRENT=20
AGENT_MASTER_MAX_CONCURRENT=100

# Hierarchical Settings
AGENT_MASTER_MAX_CHILDREN=50
AGENT_COORDINATOR_MAX_CHILDREN=10

# Logging
AGENT_LOG_LEVEL=INFO
AGENT_LOG_FILE=logs/agents.log

# Performance
AGENT_METRICS_COLLECTION_ENABLED=true
AGENT_METRICS_INTERVAL=60       # seconds

# Recovery
AGENT_AUTO_RECOVERY_ENABLED=true
AGENT_MAX_RECOVERY_ATTEMPTS=3
AGENT_RECOVERY_DELAY=5          # seconds

# API Settings
AGENT_API_ENABLED=true
AGENT_API_AUTH_REQUIRED=false   # Set to true in production

# Advanced Features
AGENT_ENABLE_DYNAMIC_SPAWNING=true
AGENT_ENABLE_HIERARCHICAL_STRUCTURE=true
AGENT_ENABLE_TASK_PRIORITIZATION=true
