# Hardhat / Contract Deployment Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.

# RPC endpoints
MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Deployer wallet private key (without 0x prefix)
# Use a dedicated deployment wallet — never your personal wallet.
PRIVATE_KEY=your_private_key_here

# Etherscan API key for contract source verification
ETHERSCAN_API_KEY=your_etherscan_api_key_here
